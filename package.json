{
  "name": "schedule-organiser",
  "version": "1.0.0",
  "description": "自用桌面日程管理工具",
  "author": "me",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite --strictPort --port 5173\" \"wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "stop": "pkill -f \"schedule-organiser.*(vite|electron \\.)\" || true",
    "build:electron": "tsc -p tsconfig.electron.json",
    "postinstall": "bash scripts/install-electron.sh 2>/dev/null || node node_modules/electron/install.js",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "pack": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^1.18.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.schedule.organiser",
    "productName": "日程",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "dmg"
      ]
    }
  }
}
